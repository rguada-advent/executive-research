{
  "name": "psg-executive-intelligence",
  "version": "2.0.0",
  "description": "PSG Human Capital Executive Intelligence - Talent Discovery & Forensic Background Analysis",
  "main": "main.js",
  "author": "PSG Human Capital",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.psg.executive-intelligence",
    "productName": "PSG Executive Intelligence",
    "copyright": "Copyright \u00c2\u00a9 2026 PSG Human Capital",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PSG Executive Intelligence",
      "guid": "C5B4E6A8-3D2F-4891-B567-8E9F0A1B2C3D"
    },
    "files": [
      "main.js",
      "preload.js",
      "frontend/**/*",
      "backend/**/*",
      "python/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc",
          "!tests/**",
          "!.pytest_cache/**"
        ]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend"
      }
    ],
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "cuufan",
      "repo": "psg-executive-intelligence"
    }
  }
}